{
    "name": "miaoda-taro-utils",
    "version": "0.0.4",
    "description": "",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./chatStream": {
            "types": "./dist/chatStream/index.d.ts",
            "import": "./dist/chatStream/index.mjs",
            "require": "./dist/chatStream/index.js"
        }
    },
    "typesVersions": {
        "*": {
            "chatStream": [
                "./dist/chatStream/index.d.ts"
            ]
        }
    },
    "files": [
        "dist",
        "package.json",
        "README.md"
    ],
    "scripts": {
        "dev": "vite build --watch",
        "build": "vite build",
        "test": "vitest",
        "clean": "rm -rf ./dist"
    },
    "keywords": [
        "taro",
        "utils",
        "chat-stream"
    ],
    "author": "",
    "license": "MIT",
    "peerDependencies": {
        "@tarojs/taro": "^4.1.0"
    },
    "dependencies": {
        "eventsource-parser": "3.0.3",
        "ky": "1.7.5"
    },
    "devDependencies": {
        "@tarojs/taro": "4.1.5",
        "@types/node": "^20.10.0",
        "@vitest/ui": "^2.1.8",
        "@vitest/coverage-v8": "^2.1.8",
        "happy-dom": "^15.11.7",
        "terser": "^5.36.0",
        "typescript": "^5.3.3",
        "vite": "^4.5.14",
        "vite-plugin-dts": "^3.7.0",
        "vitest": "^2.1.8"
    }
}
