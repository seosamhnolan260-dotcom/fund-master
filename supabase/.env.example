# Supabase Edge Functions 环境变量配置
# 复制此文件为 .env.local 并填入实际值

# ============ 盈米基金 MCP 配置 ============
# 待 PM 提供
YINGMI_MCP_ENDPOINT=
YINGMI_MCP_API_KEY=

# ============ 阿里云百炼 API 配置 ============
# 用于 AI 报告生成 (qwen3.5-plus)
QWEN_API_KEY=

# ============ Supabase 配置 ============
# 从 Supabase 项目设置中获取
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ============ 缓存配置 ============
# 基金基本信息缓存时间 (秒) - 24 小时
CACHE_FUND_INFO_TTL=86400

# 净值数据缓存时间 (秒) - 至下一交易日
CACHE_NAV_TTL=43200

# AI 报告缓存时间 (秒) - 7 天
CACHE_REPORT_TTL=604800
